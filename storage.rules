rules_version = '2';

// Deny-by-default. Solo usuarios autenticados pueden leer/escribir.
// Tier 2 (pendiente): aislar por tenant cuando exista mapeo uid -> cliente
// (custom claims o nodo /usuarios/{uid}/cliente).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
