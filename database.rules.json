{
  "rules": {
    ".read": false,
    ".write": false,

    "clientes": {
      ".read": "auth != null",
      "$clienteId": {
        ".write": "auth != null"
      }
    },

    "usuarios": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    }
  }
}
